  "targetFramework": "esrs",
  "version": "1.0",
  "lastUpdated": "2025-01-01",
  "notes": "Mapping based on EFRAG-GRI interoperability guidance published in 2023. ESRS uses double materiality (impact + financial); GRI uses impact materiality.",
  "mappings": [
    { "gri_code": "GRI 2-1", "gri_name": "Organizational details", "target_code": "ESRS 2-BP-1", "target_name": "General basis for preparation", "mapping": "equivalent", "notes": "Both require organizational identification and reporting scope" },
