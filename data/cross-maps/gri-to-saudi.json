{
  "description": "Cross-framework mapping from GRI Standards 2021 to Saudi Exchange ESG Disclosure Guidelines (29 KPIs)",
  "sourceFramework": "gri",
  "targetFramework": "saudi-exchange",
  "version": "1.0",
  "lastUpdated": "2025-01-01",
  "notes": "Saudi Exchange 29 KPIs are structured as E (Environmental), S (Social), G (Governance). Most KPIs have direct GRI equivalents. Saudi-specific KPIs (Saudization, Zakat) have partial or no GRI equivalents.",
  "mappings": [
    { "gri_code": "GRI 305-1", "gri_name": "Direct (Scope 1) GHG emissions", "target_code": "SE-E1", "target_name": "GHG Emissions", "mapping": "equivalent", "notes": "SE-E1 covers both Scope 1 and Scope 2" },
    { "gri_code": "GRI 305-2", "gri_name": "Energy indirect (Scope 2) GHG emissions", "target_code": "SE-E1", "target_name": "GHG Emissions", "mapping": "equivalent" },
    { "gri_code": "GRI 305-4", "gri_name": "GHG emissions intensity", "target_code": "SE-E2", "target_name": "Emissions Intensity", "mapping": "equivalent" },
    { "gri_code": "GRI 302-1", "gri_name": "Energy consumption within the organization", "target_code": "SE-E3", "target_name": "Energy Usage", "mapping": "equivalent" },
    { "gri_code": "GRI 302-3", "gri_name": "Energy intensity", "target_code": "SE-E3", "target_name": "Energy Usage", "mapping": "equivalent", "notes": "SE-E3 includes energy intensity" },
    { "gri_code": "GRI 303-3", "gri_name": "Water withdrawal", "target_code": "SE-E4", "target_name": "Water Usage", "mapping": "equivalent" },
    { "gri_code": "GRI 303-5", "gri_name": "Water consumption", "target_code": "SE-E4", "target_name": "Water Usage", "mapping": "equivalent" },
    { "gri_code": "GRI 306-3", "gri_name": "Waste generated", "target_code": "SE-E5", "target_name": "Waste Generated", "mapping": "equivalent" },
    { "gri_code": "GRI 2-27", "gri_name": "Compliance with laws and regulations", "target_code": "SE-E6", "target_name": "Environmental Fines", "mapping": "partial", "notes": "SE-E6 is specifically about environmental fines; GRI 2-27 is broader" },
    { "gri_code": "GRI 403-9", "gri_name": "Work-related injuries", "target_code": "SE-S1", "target_name": "Employee Health & Safety", "mapping": "equivalent" },
    { "gri_code": "GRI 418-1", "gri_name": "Substantiated privacy complaints", "target_code": "SE-S2", "target_name": "Data Privacy", "mapping": "partial" },
    { "gri_code": "GRI 404-1", "gri_name": "Average hours of training per employee", "target_code": "SE-S3", "target_name": "Employee Training", "mapping": "equivalent" },
    { "gri_code": "GRI 405-1", "gri_name": "Diversity of governance bodies and employees", "target_code": "SE-S4", "target_name": "Gender Diversity", "mapping": "equivalent" },
    { "gri_code": "GRI 2-7", "gri_name": "Employees", "target_code": "SE-S5", "target_name": "Total Employees", "mapping": "equivalent" },
    { "gri_code": "GRI 202-2", "gri_name": "Proportion of senior management hired locally", "target_code": "SE-S6", "target_name": "Nationalization/Saudization", "mapping": "partial", "notes": "GRI covers local hiring broadly; SE-S6 specifically tracks Saudi national percentage and Nitaqat compliance" },
    { "gri_code": "GRI 401-1", "gri_name": "New employee hires and employee turnover", "target_code": "SE-S7", "target_name": "Employee Turnover", "mapping": "equivalent" },
    { "gri_code": "GRI 2-30", "gri_name": "Collective bargaining agreements", "target_code": "SE-S8", "target_name": "Collective Bargaining", "mapping": "partial", "notes": "Traditional collective bargaining may not apply in Saudi Arabia" },
    { "gri_code": "GRI 405-2", "gri_name": "Ratio of basic salary women to men", "target_code": "SE-S9", "target_name": "Gender Pay Gap", "mapping": "equivalent" },
    { "gri_code": "GRI 204-1", "gri_name": "Proportion of spending on local suppliers", "target_code": "SE-S10", "target_name": "Local Procurement", "mapping": "partial", "notes": "SE-S10 specifically measures Saudi-based suppliers as part of Vision 2030 local content" },
    { "gri_code": "GRI 201-1", "gri_name": "Direct economic value generated and distributed", "target_code": "SE-S11", "target_name": "Community Investment", "mapping": "partial", "notes": "GRI 201-1 includes community investments as part of EVG&D" },
    { "gri_code": "GRI 2-9", "gri_name": "Governance structure and composition", "target_code": "SE-G1", "target_name": "Board Diversity", "mapping": "partial" },
    { "gri_code": "GRI 405-1", "gri_name": "Diversity of governance bodies and employees", "target_code": "SE-G1", "target_name": "Board Diversity", "mapping": "equivalent" },
    { "gri_code": "GRI 2-21", "gri_name": "Annual total compensation ratio", "target_code": "SE-G3", "target_name": "CEO Pay Ratio", "mapping": "partial" },
    { "gri_code": "GRI 207-1", "gri_name": "Approach to tax", "target_code": "SE-G4", "target_name": "Tax Transparency", "mapping": "partial", "notes": "SE-G4 also covers Zakat, which is Saudi-specific" },
    { "gri_code": "GRI 207-4", "gri_name": "Country-by-country reporting", "target_code": "SE-G4", "target_name": "Tax Transparency", "mapping": "partial" },
    { "gri_code": "GRI 205-1", "gri_name": "Operations assessed for corruption risks", "target_code": "SE-G5", "target_name": "Ethics & Anti-Corruption", "mapping": "equivalent" },
    { "gri_code": "GRI 205-2", "gri_name": "Anti-corruption training", "target_code": "SE-G5", "target_name": "Ethics & Anti-Corruption", "mapping": "equivalent" },
    { "gri_code": "GRI 205-3", "gri_name": "Confirmed corruption incidents", "target_code": "SE-G5", "target_name": "Ethics & Anti-Corruption", "mapping": "equivalent" },
    { "gri_code": "GRI 2-29", "gri_name": "Approach to stakeholder engagement", "target_code": "SE-G8", "target_name": "Stakeholder Engagement", "mapping": "equivalent" }
  ]
}
