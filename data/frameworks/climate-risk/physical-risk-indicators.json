{
  "id": "climate-risk-physical-indicators",
  "code": "physical-risk-indicators",
  "name": "Physical Climate Risk Indicators and Scoring Framework",
  "description": "Comprehensive physical risk indicator taxonomy covering acute and chronic climate risks, with severity scales, likelihood scoring methodology, and asset vulnerability mapping factors.",
  "version": "2024",
  "lastUpdated": "2025-01-01",
  "source": "IPCC AR6 WG2, TCFD Physical Risk Guidance, UNEP FI",
  "verified": true,
  "severityScale": {
    "1": "Negligible - minimal impact on operations or asset value",
    "2": "Low - minor disruption, manageable within normal operations",
    "3": "Moderate - significant disruption requiring adaptive response",
    "4": "High - severe impact, potential for major financial loss",
    "5": "Critical - catastrophic impact, existential threat to assets/operations"
  },
  "likelihoodScale": {
    "1": "Rare - less than 5% probability in any given year",
    "2": "Unlikely - 5-20% probability",
    "3": "Possible - 20-50% probability",
    "4": "Likely - 50-80% probability",
    "5": "Almost Certain - greater than 80% probability"
  },
  "acuteRisks": [
    {
      "id": "climate-risk-physical-acute-flood",
      "code": "phys-acute-flood",
      "name": "Flooding (Fluvial, Pluvial, Coastal)",
      "category": "acute",
      "subcategories": ["fluvial", "pluvial", "coastal", "flash"],
      "description": "Flooding events caused by extreme rainfall, river overflow, storm surge, or coastal inundation.",
      "source": "IPCC AR6 WG2",
      "verified": true,
      "parameters": {
        "severityFactors": {
          "floodDepth_m": { "low": 0.3, "moderate": 1.0, "high": 2.0, "critical": 3.0 },
          "floodDuration_days": { "low": 1, "moderate": 3, "high": 7, "critical": 30 },
          "returnPeriod_years": { "baseline": 100, "ssp1_26_2050": 50, "ssp2_45_2050": 25, "ssp5_85_2050": 10 }
        },
        "likelihoodScoring": {
          "methodology": "Combine GCM-projected precipitation extremes with local hydrological modeling and historical flood frequency analysis",
          "dataInputs": ["CMIP6 precipitation projections", "local elevation (DEM)", "historical flood records", "soil permeability", "urbanization index"],
          "adjustmentFactors": ["proximity to water body", "drainage infrastructure quality", "land use change"]
        },
        "assetVulnerabilityMapping": {
          "realEstate_commercial": { "baseSeverity": 4, "recoveryTime_months": 3, "insurabilityTrend": "decreasing" },
          "realEstate_residential": { "baseSeverity": 4, "recoveryTime_months": 6, "insurabilityTrend": "decreasing" },
          "infrastructure_transport": { "baseSeverity": 3, "recoveryTime_months": 2, "insurabilityTrend": "stable" },
          "agriculture": { "baseSeverity": 5, "recoveryTime_months": 12, "insurabilityTrend": "decreasing" },
          "manufacturing": { "baseSeverity": 4, "recoveryTime_months": 4, "insurabilityTrend": "decreasing" },
          "datacenters": { "baseSeverity": 5, "recoveryTime_months": 2, "insurabilityTrend": "stable" }
        }
      }
    },
    {
