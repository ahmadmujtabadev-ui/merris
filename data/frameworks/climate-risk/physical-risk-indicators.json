          "dataInputs": ["IBTrACS historical records", "sea surface temperature projections", "CMIP6 TC frequency", "coastal exposure"],
          "adjustmentFactors": ["latitude", "basin (Atlantic/Pacific/Indian)", "coastal vs inland distance"]
        },
        "assetVulnerabilityMapping": {
          "realEstate_commercial": { "baseSeverity": 4, "recoveryTime_months": 6, "insurabilityTrend": "decreasing" },
          "realEstate_residential": { "baseSeverity": 5, "recoveryTime_months": 12, "insurabilityTrend": "decreasing" },
          "infrastructure_energy": { "baseSeverity": 4, "recoveryTime_months": 3, "insurabilityTrend": "stable" },
          "agriculture": { "baseSeverity": 5, "recoveryTime_months": 12, "insurabilityTrend": "decreasing" },
          "offshore_oil_gas": { "baseSeverity": 4, "recoveryTime_months": 2, "insurabilityTrend": "decreasing" }
        },
        "projectedChanges": {
          "intensityIncrease_pct_per_C": 5,
          "cat4_5_frequencyIncrease_pct": 13,
          "rainfallRateIncrease_pct_per_C": 7,
          "notes": "AR6 WG1: proportion of intense TCs projected to increase; total TC frequency may decrease. Rainfall rates increase ~7%/\u00b0C."
        }
      }
