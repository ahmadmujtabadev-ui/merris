{
  "id": "validate-emissions",
  "name": "Validate Emissions Data",
  "description": "Extract emissions figures, recalculate using verified factors, flag discrepancies",
  "steps": [
    { "id": "extract", "name": "Extract emissions figures", "tool": "perceive_document", "inputs": { "documentBody": "$document", "documentType": "word" } },
    { "id": "recalculate", "name": "Recalculate with verified factors", "tool": "verify_compliance", "inputs": { "documentBody": "$document", "frameworks": ["gri"] } },
    { "id": "report", "name": "Produce validation report", "tool": "generate_text", "inputs": { "prompt": "Produce an emissions validation report from: $extract, $recalculate" } }
  ]
}
