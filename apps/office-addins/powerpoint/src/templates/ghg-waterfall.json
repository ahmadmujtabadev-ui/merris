{
  "id": "ghg-waterfall",
  "name": "GHG Emissions Waterfall",
  "description": "Scope 1 + Scope 2 + Scope 3 breakdown as a waterfall chart showing contribution of each category.",
  "layout": "single-chart",
  "placeholders": [
    { "id": "title", "type": "title", "position": { "x": 50, "y": 20, "width": 860, "height": 50 }, "dataBinding": "engagement.name" },
    { "id": "subtitle", "type": "text", "position": { "x": 50, "y": 70, "width": 860, "height": 30 }, "dataBinding": "reporting_period" },
    { "id": "waterfall", "type": "chart", "position": { "x": 50, "y": 110, "width": 860, "height": 340 }, "dataBinding": "ghg.waterfall" },
    { "id": "total", "type": "text", "position": { "x": 50, "y": 460, "width": 400, "height": 30 }, "dataBinding": "ghg.total_tco2e" },
    { "id": "methodology", "type": "text", "position": { "x": 500, "y": 460, "width": 410, "height": 30 }, "dataBinding": "ghg.methodology" }
  ]
}
