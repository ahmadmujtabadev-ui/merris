    { "id": "legend", "type": "text", "position": { "x": 770, "y": 90, "width": 140, "height": 380 }, "dataBinding": "materiality.legend" },
    { "id": "x-label", "type": "text", "position": { "x": 350, "y": 475, "width": 200, "height": 20 }, "dataBinding": "materiality.x_label" },
    { "id": "y-label", "type": "text", "position": { "x": 20, "y": 250, "width": 20, "height": 200 }, "dataBinding": "materiality.y_label" }
  ]
}
