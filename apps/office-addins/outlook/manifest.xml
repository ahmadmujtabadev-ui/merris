<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">
  <Id>merris-outlook-addin-00000000-0000-0000-0000-000000000004</Id>
  <Version>1.0.0</Version>
  <ProviderName>Merris</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Merris ESG Agent" />
  <Description DefaultValue="AI-powered ESG email assistant for Outlook. Generate data request emails from gap registers and process incoming attachments for ESG engagements." />
  <IconUrl DefaultValue="https://localhost:3004/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3004/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://merris.app/support" />

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3004/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3004/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="merrisComposeGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="generateDataRequestBtn">
                  <Label resid="generateBtnLabel" />
                  <Supertip>
                    <Title resid="generateBtnLabel" />
                    <Description resid="generateBtnDesc" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="merrisReadGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="smartReplyBtn">
                  <Label resid="smartReplyBtnLabel" />
                  <Supertip>
                    <Title resid="smartReplyBtnLabel" />
                    <Description resid="smartReplyBtnDesc" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://localhost:3004/assets/icon-16.png" />
        <bt:Image id="icon32" DefaultValue="https://localhost:3004/assets/icon-32.png" />
        <bt:Image id="icon80" DefaultValue="https://localhost:3004/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://localhost:3004/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Merris ESG" />
        <bt:String id="generateBtnLabel" DefaultValue="Generate Data Request" />
        <bt:String id="smartReplyBtnLabel" DefaultValue="Smart Reply" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="generateBtnDesc" DefaultValue="Generate a structured data request email from the ESG gap register." />
        <bt:String id="smartReplyBtnDesc" DefaultValue="Detect attachments and process them for ESG engagement ingestion." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
